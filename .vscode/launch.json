{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🧪 Test System",
            "type": "python",
            "request": "launch",
            "program": "test_system.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "🚀 Interactive Mode",
            "type": "python",
            "request": "launch",
            "program": "tutoring_cli.py",
            "args": ["interactive"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "📝 Run Question (Simulation)",
            "type": "python",
            "request": "launch",
            "program": "tutoring_cli.py",
