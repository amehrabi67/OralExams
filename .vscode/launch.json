            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "📋 List Questions",
            "type": "python",
            "request": "launch",
            "program": "tutoring_cli.py",
            "args": ["list"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "➕ Add Question",
            "type": "python",
            "request": "launch",
            "program": "tutoring_cli.py",
            "args": ["add"],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "🔍 Search Questions",
            "type": "python",
            "request": "launch",
